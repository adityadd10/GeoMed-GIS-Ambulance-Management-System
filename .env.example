# GeoMed Environment Configuration

# Security
SECRET_KEY=change-this-in-production-super-secret

# Database
# If left blank, defaults to sqlite:///geomed.db
# DATABASE_URL=postgresql://user:password@localhost:5432/geomed
DATABASE_URL=

# OpenRouteService API Key (Required for primary routing)
ORS_API_KEY=your-ors-api-key-here

# Application
FLASK_APP=app.py
FLASK_DEBUG=true
PORT=5001

# Optional GIS Ext
POSTGIS_ENABLED=false
